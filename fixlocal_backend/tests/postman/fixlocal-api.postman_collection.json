{
  "info": {
    "name": "FixLocal API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Automated coverage for FixLocal backend (auth, users, tradespersons, bookings, chat, payments, admin)."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{userName}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"USER\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('userToken', jsonData.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users & Tradespersons",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "me"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "me"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated User\",\n  \"workingCity\": \"Bangalore\",\n  \"bio\": \"Certified handyman\",\n  \"phone\": \"1234567890\"\n}"
            }
          }
        },
        {
          "name": "Tradesperson Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tradespersons/search?city=Bangalore&tag=plumbing&latitude=12.97&longitude=77.59&radiusKm=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tradespersons", "search"],
              "query": [
                {"key": "city", "value": "Bangalore"},
                {"key": "tag", "value": "plumbing"},
                {"key": "latitude", "value": "12.97"},
                {"key": "longitude", "value": "77.59"},
                {"key": "radiusKm", "value": "10"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('bookingId', jsonData.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bookings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tradespersonId\": \"{{tradespersonId}}\",\n  \"bookingStartTime\": \"2026-03-25T05:30:00Z\",\n  \"bookingEndTime\": \"2026-03-25T07:30:00Z\",\n  \"serviceAddress\": \"221B Baker St\",\n  \"serviceDescription\": \"Fix heater\",\n  \"offerAmount\": 150\n}"
            }
          }
        },
        {
          "name": "Submit Offer",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/offers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bookings", "{{bookingId}}", "offers"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 160,\n  \"message\": \"Counter offer from user\"\n}"
            }
          }
        },
        {
          "name": "Get Booking",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bookings", "{{bookingId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Get Conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('conversationId', jsonData.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/chat/conversations/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "chat", "conversations", "{{bookingId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/payments/initiate?amount=150",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bookings", "{{bookingId}}", "payments", "initiate"],
              "query": [
                {"key": "amount", "value": "150"}
              ]
            }
          }
        },
        {
          "name": "Authorize Payment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/payments/authorize",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bookings", "{{bookingId}}", "payments", "authorize"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Stats",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "stats"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "userEmail", "value": "user@mail.com" },
    { "key": "userPassword", "value": "password" },
    { "key": "userName", "value": "Test User" },
    { "key": "tradespersonId", "value": "TRADESPERSON_ID" }
  ]
}
